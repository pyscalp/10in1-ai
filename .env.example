# Router
APP_NAME=Nebius10in1Workbench
APP_ENV=local
LOG_LEVEL=info
NEBIUS_LLM_URL=http://localhost:8001/v1
NEBIUS_LLM_MODEL=Qwen/Qwen3-0.6B
NEBIUS_LLM_TOKEN=

# Supabase (local or hosted project)
SUPABASE_URL=http://localhost:54321
SUPABASE_KEY=your-anon-or-service-key
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Tool base URLs (used when running via docker compose)
CRAWL4AI_URL=http://localhost:8002
STIRLING_PDF_URL=http://localhost:8080
LANGFLOW_URL=http://localhost:7860
DIFY_URL=http://localhost:3000
DIFY_API_KEY=
OPEN_WEBUI_URL=http://localhost:8081
MAXUN_URL=http://localhost:8082
OPENHANDS_URL=http://localhost:3001
OPENHANDS_API_KEY=
COOLIFY_URL=http://localhost:3002
COOLIFY_API_TOKEN=
COOLIFY_WEBHOOK_UUID=

# Auth for the router endpoint itself (set a strong token in prod)
ROUTER_AUTH_TOKEN=change-me
